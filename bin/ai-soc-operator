#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="${AI_SOC_HOME:-$HOME/ai-soc-operator}"
if [[ ! -d "$REPO_DIR" ]]; then
  REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi

PYTHON="python3"
if [[ -x "$REPO_DIR/.venv/bin/python" ]]; then
  PYTHON="$REPO_DIR/.venv/bin/python"
fi

cd "$REPO_DIR"
exec "$PYTHON" -m web.app
